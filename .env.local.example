# Google Drive 폴더 ID (URL에서 추출: https://drive.google.com/drive/folders/[이 부분])
GDRIVE_FOLDER_ID=your_folder_id_here

# credentials.json - Google Cloud Console에서 서비스 계정 키 다운로드 후 프로젝트 루트에 배치
# 1. Google Cloud Console → API 및 서비스 → 사용자 인증 정보
# 2. 서비스 계정 만들기 → JSON 키 다운로드
# 3. Google Drive API 활성화
# 4. 드라이브 폴더를 서비스 계정 이메일과 공유
